CODY_PROXY_ENABLED=1
HTTPS_PROXY=http://localhost:9999
HTTP_PROXY=http://localhost:9999
NO_PROXY=localhost,127.0.0.1,::1,192.168.68.68
# If using a remote proxy rotator (e.g. Proxmox host), define the control URL here
# and ensure its IP is added to NO_PROXY to prevent self-proxy loops.
# CODY_PROXY_CONTROL_URL=http://192.168.68.68:8888
# Optional upstream Proxmox HTTP proxy route used after healthy Tor routes are exhausted.
# CODY_PROXMOX_PROXY_URL=http://192.168.68.68:8888
