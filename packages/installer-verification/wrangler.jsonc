{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "installer-verification-local",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "InstallerVerificationDatabase",
      "database_name": "installer-verification-local",
      "database_id": "local",
      "migrations_dir": "migrations"
    }
  ]
}
